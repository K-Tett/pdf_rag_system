# PDF RAG System Environment Configuration

# =============================================================================
# BASIC CONFIGURATION (Most users only need this section)
# =============================================================================

# OpenAI API Key (Optional but recommended for better performance)
# Get your API key from: https://platform.openai.com/account/api-keys
# Leave empty to use only Ollama (works fine for most cases)
OPENAI_API_KEY=

# Application Environment
ENVIRONMENT=development

# =============================================================================
# ADVANCED CONFIGURATION (Optional - system works with defaults)
# =============================================================================

# Database Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=pdf_documents

# Primary LLM (Ollama) - Works out of the box
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Fallback LLM (OpenAI) - Only used if OPENAI_API_KEY is set
OPENAI_MODEL=gpt-4-1106-preview

# Document Processing (adjust if needed)
CHUNK_SIZE=512
CHUNK_OVERLAP=50
RETRIEVAL_TOP_K=10
RERANK_TOP_K=3

# File Storage Directories
DATA_DIR=./data
LOGS_DIR=./logs

# =============================================================================
# YOU'RE DONE! 
# =============================================================================
# Save this file as .env and run: docker-compose up -d
# Then open http://localhost:8501 in your browser